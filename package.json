{
  "name": "amt-integration-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:nextjs": "npm run dev --workspace=@amt-integration/nextjs",
    "dev:react-helmet": "npm run start --workspace=@amt-integration/react-helmet",
    "build:nextjs": "npm run build --workspace=@amt-integration/nextjs",
    "build:react-helmet": "npm run build --workspace=@amt-integration/react-helmet"
  }
}
